generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum Plan {
  free
  pro
  enterprise
}

enum Platform {
  facebook
  instagram
  line
  whatsapp
  web
  manual
}

enum ConversationStatus {
  pending
  open
  resolved
  closed
}

enum Priority {
  low
  medium
  high
  urgent
}

enum Sentiment {
  positive
  neutral
  negative
}

enum SenderType {
  contact
  agent
  bot
  system
}

enum ContentType {
  text
  image
  file
  sticker
  location
  template
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

// ─── Models ───

enum NotificationType {
  assignment
  transfer
  sla_warning
  sla_breach
  mention
  system
}

enum NoteableType {
  conversation
  contact
}

enum FileType {
  image
  video
  pdf
  document
  other
}

enum TemplateCategory {
  greeting
  pricing
  shipping
  closing
  custom
}

enum CapiEventStatus {
  pending
  sent
  failed
  retrying
}

enum SyncLogType {
  product_sync
  customer_sync
  order_push
  webhook_order_status
  webhook_stock_update
  webhook_customer_update
}

enum AiBotMode {
  off
  confirm
  full_auto
}

enum AiReplyStatus {
  auto_sent
  pending_review
  approved
  edited
  rejected
  escalated
}

enum KbCategory {
  faq
  product
  policy
  promotion
  store_info
  other
}

enum SyncLogStatus {
  success
  failed
}

enum SyncLogDirection {
  inbound
  outbound
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      Plan     @default(free)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  users               User[]
  roles               Role[]
  memberships         OrgMembership[]
  channels            Channel[]
  contacts            Contact[]
  conversations       Conversation[]
  orders              Order[]
  quickReplyTemplates QuickReplyTemplate[]
  notes               Note[]
  mediaFolders        MediaFolder[]
  mediaFiles          MediaFile[]
  aiBotConfigs        AiBotConfig[]
  knowledgeArticles   KnowledgeArticle[]
  aiReplyLogs         AiReplyLog[]
  contactLabels       ContactLabel[]
  messageSets         MessageSet[]
  botIntents          BotIntent[]

  @@map("organizations")
}

model Role {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  name         String
  description  String?
  permissions  Json     @default("[]")
  isSystemRole Boolean  @default(false) @map("is_system_role")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users        User[]
  memberships  OrgMembership[]

  @@map("roles")
}

model User {
  id                 String   @id @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  email              String
  name               String
  roleId             String   @map("role_id") @db.Uuid
  avatarUrl          String?  @map("avatar_url")
  isActive           Boolean  @default(true) @map("is_active")
  isAvailable        Boolean  @default(true) @map("is_available")
  maxConcurrentChats Int      @default(10) @map("max_concurrent_chats")
  createdAt          DateTime @default(now()) @map("created_at")

  organization          Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role                  Role               @relation(fields: [roleId], references: [id])
  assignedConversations Conversation[]     @relation("AssignedAgent")
  notifications         Notification[]
  memberships           OrgMembership[]
  conversationReads     ConversationRead[]

  @@map("users")
}

model OrgMembership {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, orgId])
  @@index([userId])
  @@map("org_memberships")
}

model Channel {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  platform    Platform
  name        String
  credentials Json     @default("{}") @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  capiDatasets  CapiDataset[]
  botIntents    BotIntent[]

  @@map("channels")
}

model Contact {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  platformId         String   @map("platform_id")
  platform           Platform
  displayName        String?  @map("display_name")
  avatarUrl          String?  @map("avatar_url")
  phone              String?
  email              String?
  tags               String[] @default([])
  segment            String?
  erpCustomerId      String?  @map("erp_customer_id")
  firstSeenAt        DateTime @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime @default(now()) @map("last_seen_at")
  totalConversations Int      @default(0) @map("total_conversations")
  totalOrders        Int      @default(0) @map("total_orders")
  totalRevenue       Decimal  @default(0) @db.Decimal(12, 2) @map("total_revenue")
  metadata           Json     @default("{}") @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at")

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  orders        Order[]

  @@unique([orgId, platformId, platform])
  @@map("contacts")
}

model Conversation {
  id                  String             @id @default(uuid()) @db.Uuid
  orgId               String             @map("org_id") @db.Uuid
  channelId           String             @map("channel_id") @db.Uuid
  contactId           String             @map("contact_id") @db.Uuid
  assignedTo          String?            @map("assigned_to") @db.Uuid
  status              ConversationStatus @default(open)
  priority            Priority           @default(medium)
  sourceAdId          String?            @map("source_ad_id")
  sourceAdName        String?            @map("source_ad_name")
  sourcePlacement     String?            @map("source_placement")
  sourceCampaignId    String?            @map("source_campaign_id")
  sourceUtm           Json?              @map("source_utm") @db.JsonB
  psid                String?
  igsid               String?
  ctwaClid            String?            @map("ctwa_clid")
  isReturningCustomer Boolean            @default(false) @map("is_returning_customer")
  startedAt           DateTime?          @map("started_at")
  firstResponseAt     DateTime?          @map("first_response_at")
  resolvedAt          DateTime?          @map("resolved_at")
  aiSummary           String?            @map("ai_summary")
  aiSentiment         Sentiment?         @map("ai_sentiment")
  aiIntent            String?            @map("ai_intent")
  dropOffReason       String?            @map("drop_off_reason")
  slaFirstResponseDeadline DateTime?       @map("sla_first_response_deadline")
  slaResolutionDeadline    DateTime?       @map("sla_resolution_deadline")
  slaBreachedAt       DateTime?          @map("sla_breached_at")
  slaWarningAt        DateTime?          @map("sla_warning_at")
  lastMessageAt       DateTime?          @map("last_message_at")
  labels              String[]           @default([])
  metadata            Json               @default("{}") @db.JsonB
  createdAt           DateTime           @default(now()) @map("created_at")

  organization  Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channel       Channel             @relation(fields: [channelId], references: [id])
  contact       Contact             @relation(fields: [contactId], references: [id])
  assignedUser  User?               @relation("AssignedAgent", fields: [assignedTo], references: [id])
  messages      Message[]
  events        ConversationEvent[]
  orders        Order[]
  aiReplyLogs   AiReplyLog[]
  reads         ConversationRead[]
  intentSessions IntentSession[]

  @@index([orgId, status])
  @@index([orgId, assignedTo])
  @@index([orgId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id                String      @id @default(uuid()) @db.Uuid
  conversationId    String      @map("conversation_id") @db.Uuid
  senderType        SenderType  @map("sender_type")
  senderId          String?     @map("sender_id") @db.Uuid
  content           String?
  contentType       ContentType @default(text) @map("content_type")
  mediaUrl          String?     @map("media_url")
  platformMessageId String?     @map("platform_message_id")
  isAiSuggested     Boolean     @default(false) @map("is_ai_suggested")
  metadata          Json        @default("{}") @db.JsonB
  createdAt         DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model ConversationRead {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  lastReadAt     DateTime @map("last_read_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@map("conversation_reads")
}

model ConversationEvent {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  eventType      String   @map("event_type")
  actorId        String?  @map("actor_id") @db.Uuid
  metadata       Json     @default("{}") @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("conversation_events")
}

model ContactLabel {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@map("contact_labels")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  orgId           String      @map("org_id") @db.Uuid
  conversationId  String?     @map("conversation_id") @db.Uuid
  contactId       String      @map("contact_id") @db.Uuid
  orderNumber     String      @map("order_number")
  amount          Decimal     @db.Decimal(12, 2)
  status          OrderStatus @default(pending)
  items           Json        @default("[]") @db.JsonB
  sourceAdId      String?     @map("source_ad_id")
  sourcePlacement String?     @map("source_placement")
  erpOrderId      String?     @map("erp_order_id")
  erpSyncedAt     DateTime?   @map("erp_synced_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])

  @@map("orders")
}

model QuickReplyTemplate {
  id           String           @id @default(uuid()) @db.Uuid
  orgId        String           @map("org_id") @db.Uuid
  name         String
  content      String
  category     TemplateCategory @default(custom)
  shortcut     String?
  templateType String           @default("text") @map("template_type")
  buttons      Json?            @db.JsonB
  imageUrl     String?          @map("image_url")
  isActive     Boolean          @default(true) @map("is_active")
  usageCount   Int              @default(0) @map("usage_count")
  createdBy    String           @map("created_by") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
  @@map("quick_reply_templates")
}

model Note {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @map("org_id") @db.Uuid
  noteableType NoteableType @map("noteable_type")
  noteableId   String       @map("noteable_id") @db.Uuid
  content      String
  mentions     String[]     @default([]) @db.Uuid
  authorId     String       @map("author_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, noteableType, noteableId])
  @@map("notes")
}

model MediaFolder {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  parentId  String?  @map("parent_id") @db.Uuid
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent       MediaFolder?  @relation("FolderParent", fields: [parentId], references: [id])
  children     MediaFolder[] @relation("FolderParent")
  files        MediaFile[]

  @@index([orgId, parentId])
  @@map("media_folders")
}

model MediaFile {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  folderId     String?   @map("folder_id") @db.Uuid
  originalName String    @map("original_name")
  storageKey   String    @map("storage_key")
  fileType     FileType  @map("file_type")
  mimeType     String    @map("mime_type")
  fileSize     BigInt    @map("file_size")
  width        Int?
  height       Int?
  thumbnailKey String?   @map("thumbnail_key")
  tags         String[]  @default([])
  description  String?
  altText      String?   @map("alt_text")
  usageCount   Int       @default(0) @map("usage_count")
  uploadedBy   String    @map("uploaded_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  folder       MediaFolder? @relation(fields: [folderId], references: [id])

  @@index([orgId, folderId])
  @@index([orgId, fileType])
  @@map("media_files")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  orgId     String           @map("org_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SlaConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  orgId                String   @map("org_id") @db.Uuid
  priority             Priority
  firstResponseMinutes Int      @map("first_response_minutes")
  resolutionMinutes    Int      @map("resolution_minutes")
  isActive             Boolean  @default(true) @map("is_active")
  escalateTo           String?  @map("escalate_to") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([orgId, priority])
  @@map("sla_configs")
}

model CapiDataset {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  channelId        String   @map("channel_id") @db.Uuid
  datasetId        String   @map("dataset_id")
  platform         Platform
  platformEntityId String   @map("platform_entity_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")

  channel    Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  capiEvents CapiEvent[]

  @@unique([channelId])
  @@index([orgId])
  @@map("capi_datasets")
}

model CapiEvent {
  id               String          @id @default(uuid()) @db.Uuid
  orgId            String          @map("org_id") @db.Uuid
  datasetId        String          @map("dataset_id") @db.Uuid
  eventId          String          @map("event_id")
  eventName        String          @map("event_name")
  actionSource     String          @default("business_messaging") @map("action_source")
  messagingChannel String          @map("messaging_channel")
  userData         Json            @default("{}") @db.JsonB @map("user_data")
  customData       Json            @default("{}") @db.JsonB @map("custom_data")
  status           CapiEventStatus @default(pending)
  errorMessage     String?         @map("error_message")
  retryCount       Int             @default(0) @map("retry_count")
  sentAt           DateTime?       @map("sent_at")
  conversationId   String?         @map("conversation_id") @db.Uuid
  orderId          String?         @map("order_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")

  dataset CapiDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([eventId])
  @@index([orgId, status])
  @@index([orgId, eventName])
  @@map("capi_events")
}

model SyncLog {
  id              String           @id @default(uuid()) @db.Uuid
  orgId           String           @map("org_id") @db.Uuid
  type            SyncLogType
  direction       SyncLogDirection
  entityId        String?          @map("entity_id")
  status          SyncLogStatus
  requestPayload  Json?            @db.JsonB @map("request_payload")
  responsePayload Json?            @db.JsonB @map("response_payload")
  errorMessage    String?          @map("error_message")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([orgId, type])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("sync_logs")
}

model AiBotConfig {
  id                               String     @id @default(uuid()) @db.Uuid
  orgId                            String     @map("org_id") @db.Uuid
  channelId                        String?    @map("channel_id") @db.Uuid
  mode                             AiBotMode  @default(off)
  useBusinessHours                 Boolean    @default(false) @map("use_business_hours")
  autoMode                         AiBotMode  @default(full_auto) @map("auto_mode")
  manualMode                       AiBotMode  @default(confirm) @map("manual_mode")
  persona                          String?
  escalationMaxRounds              Int        @default(5) @map("escalation_max_rounds")
  escalationOnNegativeSentiment    Boolean    @default(true) @map("escalation_on_negative_sentiment")
  escalationOnRefund               Boolean    @default(true) @map("escalation_on_refund")
  escalationOnLowConfidence        Decimal    @default(0.5) @db.Decimal(3, 2) @map("escalation_on_low_confidence")
  greetingMessage                  String?    @map("greeting_message")
  isActive                         Boolean    @default(false) @map("is_active")
  createdAt                        DateTime   @default(now()) @map("created_at")
  updatedAt                        DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channelId])
  @@index([orgId])
  @@map("ai_bot_configs")
}

model KnowledgeArticle {
  id         String     @id @default(uuid()) @db.Uuid
  orgId      String     @map("org_id") @db.Uuid
  title      String
  content    String
  category   KbCategory @default(faq)
  tags       String[]   @default([])
  isActive   Boolean    @default(true) @map("is_active")
  usageCount Int        @default(0) @map("usage_count")
  createdBy  String?    @map("created_by") @db.Uuid
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category])
  @@index([orgId, isActive])
  @@map("knowledge_articles")
}

model AiReplyLog {
  id             String        @id @default(uuid()) @db.Uuid
  orgId          String        @map("org_id") @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  messageId      String?       @map("message_id") @db.Uuid
  mode           AiBotMode
  draftContent   String        @map("draft_content")
  finalContent   String?       @map("final_content")
  status         AiReplyStatus @default(pending_review)
  confidence     Decimal       @default(0) @db.Decimal(3, 2)
  shouldEscalate Boolean       @default(false) @map("should_escalate")
  escalateReason String?       @map("escalate_reason")
  usedSources    String[]      @default([]) @map("used_sources")
  kbArticleIds   String[]      @default([]) @map("kb_article_ids") @db.Uuid
  reviewedBy     String?       @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?     @map("reviewed_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([conversationId])
  @@index([orgId, createdAt])
  @@map("ai_reply_logs")
}

// ─── Message Sets & Bot Intents (Chatcone-Style) ─────────────────────────────

model MessageSet {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  messages  Json     @default("{}") @db.JsonB
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  intentLinks  BotIntentMessageSet[]

  @@index([orgId])
  @@map("message_sets")
}

model BotIntent {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  name          String
  isActive      Boolean  @default(false) @map("is_active")
  triggerType   String   @map("trigger_type")
  keywords      String[] @default([])
  postbackData  String?  @map("postback_data")
  channelId     String?  @map("channel_id") @db.Uuid
  priority      Int      @default(0)
  assignToHuman Boolean  @default(false) @map("assign_to_human")
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channel      Channel?              @relation(fields: [channelId], references: [id])
  sessions     IntentSession[]
  messageSets  BotIntentMessageSet[]

  @@index([orgId, isActive])
  @@map("bot_intents")
}

model BotIntentMessageSet {
  id           String @id @default(uuid()) @db.Uuid
  intentId     String @map("intent_id") @db.Uuid
  messageSetId String @map("message_set_id") @db.Uuid
  order        Int    @default(0)

  intent     BotIntent  @relation(fields: [intentId], references: [id], onDelete: Cascade)
  messageSet MessageSet @relation(fields: [messageSetId], references: [id], onDelete: Cascade)

  @@unique([intentId, messageSetId])
  @@index([intentId])
  @@map("bot_intent_message_sets")
}

model IntentSession {
  id             String    @id @default(uuid()) @db.Uuid
  intentId       String    @map("intent_id") @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  status         String    @default("active")
  sentCount      Int       @default(0) @map("sent_count")
  totalMessages  Int       @default(0) @map("total_messages")
  errors         String[]  @default([])
  variables      Json      @default("{}") @db.JsonB
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")

  intent       BotIntent    @relation(fields: [intentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([intentId, conversationId])
  @@index([conversationId, status])
  @@map("intent_sessions")
}
